<Window
    x:Class="SmartSpectraWinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#14141C" RequestedTheme="Dark">

        <!-- Camera preview, behind everything. -->
        <Image x:Name="PreviewImage" Stretch="Uniform" />

        <!-- Validation hint pill, top-center. -->
        <Border x:Name="ValidationPill"
                Background="#A0000000" CornerRadius="14"
                Padding="16,8" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,24,0,0" Visibility="Collapsed">
            <TextBlock x:Name="ValidationText"
                       Foreground="White" FontWeight="SemiBold" FontSize="14"/>
        </Border>

        <!-- Bottom panel with vertical gradient overlay. -->
        <Grid VerticalAlignment="Bottom" Padding="24,32,24,24">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#DC000000" Offset="0.25"/>
                    <GradientStop Color="#F5000000" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="StatusText" Grid.Row="0" Text="Idle"
                       Foreground="#80FFFFFF" FontSize="14" Margin="0,0,0,8"/>

            <Grid Grid.Row="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="14"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="HeartRateText" Text="-- bpm"
                               Foreground="#FF6B6B" FontSize="32" FontWeight="Bold"
                               VerticalAlignment="Bottom"/>
                    <TextBlock x:Name="HrvText" Text=""
                               Foreground="#B0FFFFFF" FontSize="14"
                               VerticalAlignment="Bottom" Margin="0,0,0,7"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Spacing="10">
                    <TextBlock x:Name="ExpressionEmoji" FontSize="32"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ExpressionText" FontSize="14"
                               Foreground="#B0FFFFFF" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <TextBlock x:Name="BreathingRateText" Grid.Row="2" Text="Breathing Rate"
                       Foreground="White" FontSize="14" Margin="0,0,0,12"/>

            <Grid Grid.Row="3" Height="100" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <TextBlock Text="Breathing" Foreground="#80FFFFFF" FontSize="11"
                               VerticalAlignment="Top"/>
                    <Canvas x:Name="BreathingCanvas" Margin="0,18,0,0"
                            SizeChanged="OnGraphCanvasSizeChanged"/>
                </Grid>
                <Grid Grid.Column="2">
                    <TextBlock Text="Arterial Pressure" Foreground="#80FFFFFF" FontSize="11"
                               VerticalAlignment="Top"/>
                    <Canvas x:Name="BpCanvas" Margin="0,18,0,0"
                            SizeChanged="OnGraphCanvasSizeChanged"/>
                </Grid>
            </Grid>

            <TextBlock x:Name="InsightText" Grid.Row="4"
                       Text="Tap Ask AI to get an analysis of your vitals."
                       Foreground="White" FontSize="13" TextWrapping="Wrap"
                       MaxLines="3" Margin="0,0,0,16"/>

            <StackPanel Grid.Row="5" Orientation="Horizontal"
                        HorizontalAlignment="Right" Spacing="12">
                <Button x:Name="InsightButton" Content="Ask AI"
                        Click="OnInsightClick" MinWidth="120"/>
                <Button x:Name="ToggleButton" Content="Start"
                        Click="OnToggleClick" MinWidth="120"
                        Style="{ThemeResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
