<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/expression_status_background"
    android:paddingVertical="6dp">

    <TextView
        android:id="@+id/expressionLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/expression_label"
        android:textColor="@color/orange_dark"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textAlignment="viewStart"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/expressionValueContainer"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <LinearLayout
        android:id="@+id/expressionValueContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/expressionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/orange"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Happy" />

        <TextView
            android:id="@+id/expressionConfidence"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/expression_confidence_default"
            android:textColor="@color/gray"
            android:textSize="12sp"
            android:maxLines="1" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
